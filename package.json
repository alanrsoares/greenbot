{
  "name": "@greenbot/cli",
  "version": "0.40.1",
  "packageManager": "bun@1.3.4",
  "keywords": [
    "greenbot",
    "cli",
    "package updater"
  ],
  "description": "An interactive package updater for npm based applications",
  "homepage": "https://github.com/alanrsoares/greenbot",
  "repository": {
    "type": "git",
    "url": "https://github.com/alanrsoares/greenbot.git"
  },
  "license": "MIT",
  "files": [
    "dist/",
    "bin/",
    "scripts/"
  ],
  "bin": "./dist/bin/greenbot.js",
  "type": "module",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "check": "knip && tsc --noEmit",
    "format": "prettier --write .",
    "postversion": "bun run build && git add . && git commit --amend --no-edit",
    "release": "bun publish && git push && git push --tags",
    "prepare": "husky || true",
    "prebuild": "node scripts/prebuild.mjs",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/js-yaml": "^4.0.9",
    "chalk": "^4.1.2",
    "husky": "^9.1.7",
    "knip": "^6.27.0",
    "prettier": "^3.9.5",
    "pretty-quick": "^4.2.2",
    "strip-ansi": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "zx": "^8.8.5"
  },
  "dependencies": {
    "@clack/core": "^1.4.3",
    "@clack/prompts": "^1.7.0",
    "js-yaml": "^4.3.0",
    "package-json": "^10.0.1",
    "replace-in-file": "^7.2.0"
  }
}
